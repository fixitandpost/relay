{
  "name": "relay-ui",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "electron .",
    "package": "npm run build && npx electron-packager . Relay --platform=darwin --arch=arm64 --out=release --overwrite --app-bundle-id=com.relay.app --extend-info=build/Info.plist --extra-resource=../mediamtx --extra-resource=../mediamtx.yml",
    "sign": "bash build/sign.sh",
    "dist": "npm run package && npm run sign"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-packager": "^17.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
